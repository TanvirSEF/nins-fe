# Version control
.git
.gitignore
.gitattributes

# Next.js build output (regenerated inside the image)
.next
out

# Dependencies (installed fresh inside the image)
node_modules
.pnpm-store

# Local env — never bake into a layer; the build ARG supplies NEXT_PUBLIC_API_URL
.env
.env.*
!.env.example

# Test / coverage / tooling artifacts
coverage
*.log
npm-debug.log*
pnpm-debug.log*
.vscode
.idea

# Docker artifacts themselves aren't needed in the build context
Dockerfile
docker-compose*.yml
.dockerignore

# Docs / misc
README.md
docs
**/*.md
.DS_Store
